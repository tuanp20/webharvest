# ═══════════════════════════════════════════════════════════════
#  WebHarvest License Server — Environment Variables
#  Copy to .env and fill in real values.
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection
DATABASE_URL=postgresql://webharvest:webharvest@localhost:5432/webharvest_license

# PayOS credentials (get from PayOS dashboard)
PAYOS_CLIENT_ID=replace_with_payos_client_id
PAYOS_API_KEY=replace_with_payos_api_key
PAYOS_CHECKSUM_KEY=replace_with_payos_checksum_key
PAYOS_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# Admin dashboard password (CHANGE THIS!)
ADMIN_PASSWORD=your_secure_admin_password

# Server config
HOST=0.0.0.0
PORT=8443
DEBUG=false

# CORS origins (comma-separated, * for all)
CORS_ORIGINS=*
